doctype html
html
  head
    title Oficina Central de Reparações
    meta(charset='utf-8')
    style.
      body { font-family: Arial, sans-serif; margin: 40px; background-color: #f9f9f9; }
      h1, h2, h3 { color: #333; }
      table { border-collapse: collapse; width: 100%; margin-top: 20px; background-color: white; }
      th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
      th { background-color: #007bff; color: white; }
      tr:nth-child(even) { background-color: #f2f2f2; }
      a { color: #007bff; text-decoration: none; font-weight: bold; }
      a:hover { text-decoration: underline; }
      .container { max-width: 1200px; margin: auto; }
      .btn { display: inline-block; padding: 10px 15px; background: #333; color: white; border-radius: 5px; margin-top: 20px;}
  body
    div.container
      block content